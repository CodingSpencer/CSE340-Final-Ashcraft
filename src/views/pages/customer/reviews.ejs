<h1>My Reviews</h1>

<%- include('../../partials/flash-messages') %>

<% if (reviews && reviews.length > 0) { %>
    <div class="review-cards">
        <% reviews.forEach((review) => { %>
            <div class="review-card">
                <div class="review-card-header">
                    <span class="review-vehicle">
                        <strong>Vehicle:</strong> 
                        <% if (review.vehicle) { %>
                            <a href="/inventory/<%= review.vehicle_id %>"><%= review.vehicle.year %> <%= review.vehicle.make %> <%= review.vehicle.model %></a>
                        <% } else { %>
                            Unknown Vehicle
                        <% } %>
                    </span>
                    <span class="review-rating">
                        <% for (let i = 1; i <= 5; i++) { %>
                            <span class="star <%= i <= review.rating ? 'filled' : '' %>">&#9733;</span>
                        <% } %>
                    </span>
                </div>
                <div class="review-card-body">
                    <p><%= review.review_text %></p>
                </div>
                <div class="review-card-footer">
                    <span class="review-date">Posted: <%= new Date(review.created_at).toLocaleDateString() %></span>
                    <div class="review-actions">
                        <a href="/my-reviews/<%= review.id %>/edit" class="btn btn-sm">Edit</a>
                        <form method="POST" action="/my-reviews/<%= review.id %>/delete" style="display:inline;">
                            <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this review?')">Delete</button>
                        </form>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
<% } else { %>
    <p>You have not written any reviews yet.</p>
    <a href="/inventory" class="btn">Browse Vehicles to Review</a>
<% } %>

<div class="dashboard-link">
    <a href="/dashboard">&larr; Back to Dashboard</a>
</div>