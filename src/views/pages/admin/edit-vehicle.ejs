<h1>Edit Vehicle</h1>

<%- include('../../partials/flash-messages') %>

<form method="POST" action="/admin/vehicles/<%= vehicle.id %>/update" class="vehicle-form">
    <div class="form-group">
        <label for="category_id">Category:</label>
        <select name="category_id" id="category_id" required>
            <option value="">Select Category</option>
            <option value="1" <%= vehicle.category_id === 1 ? 'selected' : '' %>>Cars</option>
            <option value="2" <%= vehicle.category_id === 2 ? 'selected' : '' %>>Trucks</option>
            <option value="3" <%= vehicle.category_id === 3 ? 'selected' : '' %>>SUVs</option>
            <option value="4" <%= vehicle.category_id === 4 ? 'selected' : '' %>>Vans</option>
        </select>
    </div>

    <div class="form-group">
        <label for="make">Make:</label>
        <input type="text" name="make" id="make" value="<%= vehicle.make %>" required>
    </div>

    <div class="form-group">
        <label for="model">Model:</label>
        <input type="text" name="model" id="model" value="<%= vehicle.model %>" required>
    </div>

    <div class="form-group">
        <label for="year">Year:</label>
        <input type="number" name="year" id="year" min="1900" max="2030" value="<%= vehicle.year %>" required>
    </div>

    <div class="form-group">
        <label for="mileage">Mileage:</label>
        <input type="number" name="mileage" id="mileage" min="0" value="<%= vehicle.mileage %>" required>
    </div>

    <div class="form-group">
        <label for="price">Price:</label>
        <input type="number" name="price" id="price" min="0" step="0.01" value="<%= vehicle.price %>" required>
    </div>

    <div class="form-group">
        <label for="description">Description:</label>
        <textarea name="description" id="description" rows="4"><%= vehicle.description %></textarea>
    </div>

    <div class="form-group">
        <label for="availability">Available:</label>
        <input type="checkbox" name="availability" id="availability" <%= vehicle.availability ? 'checked' : '' %>>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Update Vehicle</button>
        <a href="/admin/vehicles" class="btn btn-secondary">Cancel</a>
    </div>
</form>