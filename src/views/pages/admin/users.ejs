<h1>Manage Users</h1>

<%- include('../../partials/flash-messages') %>

<% if (users && users.length > 0) { %>
    <div class="user-cards">
        <% users.forEach((user) => { %>
            <div class="user-card admin">
                <div class="user-card-content">
                    <h3><%= user.name %></h3>
                    <p><strong>Email:</strong> <%= user.email %></p>
                    <p><strong>Role:</strong> <%= user.roleName %></p>
                </div>
                <div class="user-card-actions">
                    <form method="POST" action="/admin/users/<%= user.id %>/delete" style="display:inline;">
                        <button type="submit" class="btn btn-danger btn-sm" data-confirm="Are you sure you want to delete this user?">Delete User</button>
                    </form>
                </div>
            </div>
        <% }) %>
    </div>
<% } else { %>
    <p>No users have been added yet.</p>
<% } %>

<div class="dashboard-link">
    <a href="/dashboard">&larr; Back to Dashboard</a>
</div>