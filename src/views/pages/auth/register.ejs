<main class="login-page">
    <%- include('../../partials/flash-messages') %>
    <h1>Create an account</h1>
    <p>
        Register to start renting vehicles from Cougar Car Rental.
    </p>

    <form method="POST" action="/account/register" class="login-form" novalidate>
        <div class="form-group">
            <label for="name">Full Name</label>
            <input type="text" id="name" name="name" placeholder="Enter your full name" required>
        </div>

        <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" placeholder="Enter your email address" required>
        </div>

        <div class="form-group">
            <label for="password">Password</label>
            <input type="password" id="password" name="password" minlength="8" placeholder="Create a password (min 8 characters)" required>
        </div>

        <button type="submit" class="btn btn-primary">Register</button>

        <div class="form-footer">
            <p>Already have an account? <a href="/login">Log in</a></p>
        </div>
    </form>
</main>