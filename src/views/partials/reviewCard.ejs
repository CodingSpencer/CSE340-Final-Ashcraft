<div class="review-card">
    <div class="review-card-header">
        <span class="review-author"><%= review.user ? review.user.name : 'Anonymous' %></span>
        <span class="review-rating">
            <% for (let i = 1; i <= 5; i++) { %>
                <span class="star <%= i <= review.rating ? 'filled' : '' %>">&#9733;</span>
            <% } %>
        </span>
    </div>
    <div class="review-card-body">
        <p><%= review.review_text %></p>
    </div>
    <div class="review-card-footer">
        <span class="review-date"><%= new Date(review.created_at).toLocaleDateString() %></span>
        <% if (isLoggedIn) { %>
            <% if (user.roleName === 'admin' || user.roleName === 'employee') { %>
                <!-- Admin/Employee can delete any review -->
                <form method="POST" action="/admin/reviews/<%= review.id %>/delete" style="display:inline;">
                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this review?')">Delete</button>
                </form>
            <% } else if (review.user_id === user.id) { %>
                <!-- Customer can edit/delete their own review -->
                <a href="/my-reviews/<%= review.id %>/edit" class="btn btn-sm">Edit</a>
                <form method="POST" action="/my-reviews/<%= review.id %>/delete" style="display:inline;">
                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this review?')">Delete</button>
                </form>
            <% } %>
        <% } %>
    </div>
</div>